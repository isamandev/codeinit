# Backend Environment Variables

# Database (configured by docker-compose)
DATABASE_URL="postgresql://codeinit:codeinit_password@postgres:5432/codeinit"

# API
PORT=3001
FRONTEND_URL=http://localhost:3000

# Telegram (optional, for Phase 2)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# JWT (for future auth)
JWT_SECRET=dev-secret-change-in-production
JWT_EXPIRATION=24h

# Crawler (optional, for Phase 2)
CRAWLER_ENABLED=false
