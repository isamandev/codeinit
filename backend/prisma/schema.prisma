// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated"
}

datasource db {
  provider = "postgresql"
}

// Job model for storing job listings
model Job {
  id            String   @id @default(cuid())
  title         String
  company       String
  description   String?
  location      String?
  employmentType String?
  skills        String[]
  url           String   @unique
  source        String   // Source of the job (jobinja, quera, etc.)
  sourceId      String?  // ID from the source website

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  notificationsSent NotificationLog[]

  @@index([source])
  @@index([createdAt])
  @@map("jobs")
}

// Role enum for authorization
enum Role {
  USER
  ADMIN
}

// User model for future authentication
model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?

  password      String?
  role          Role     @default(USER)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  pushSubscriptions PushSubscription[]
  lessonProgress    LessonProgress[]

  @@map("users")
}

// Course model — a course is an ordered list of chapters
model Course {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  chapters    Chapter[]

  @@map("courses")
}

// Chapter model — an ordered list of lessons within a course
model Chapter {
  id       String @id @default(cuid())
  courseId String
  title    String
  order    Int

  // Relations
  course   Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons  Lesson[]

  @@index([courseId])
  @@map("chapters")
}

// Lesson model — a single lesson's full content
model Lesson {
  id        String @id @default(cuid())
  chapterId String
  title     String
  order     Int

  duration   String?
  videoLabel String?
  intro      String?
  codeBlock  String?
  body       String?

  // Relations
  chapter  Chapter           @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  progress LessonProgress[]

  @@index([chapterId])
  @@map("lessons")
}

// LessonProgress model — tracks per-user lesson completion
model LessonProgress {
  id          String   @id @default(cuid())
  userId      String
  lessonId    String
  completedAt DateTime @default(now())

  // Relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
  @@map("lesson_progress")
}

// Push subscription model for Web Push notifications
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String?
  endpoint  String   @unique
  keys      Json     // Contains p256dh and auth
  active    Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

// Job source configuration for crawler management
model JobSource {
  id        String   @id @default(cuid())
  name      String   @unique
  url       String
  active    Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("job_sources")
}

// Notification log for tracking sent notifications
model NotificationLog {
  id              String   @id @default(cuid())
  jobId           String
  notificationType String  // 'telegram' | 'push' | 'email'
  status          String   // 'pending' | 'sent' | 'failed'
  error           String?

  sentAt          DateTime?
  createdAt       DateTime @default(now())

  // Relations
  job             Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([notificationType])
  @@index([createdAt])
  @@map("notification_logs")
}
