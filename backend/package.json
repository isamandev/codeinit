{
  "name": "@codeinit/backend",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "CodeInit Backend - NestJS API Server",
  "scripts": {
    "dev": "npm run build --silent && concurrently -k -n tsc,node \"tsc -p tsconfig.json --watch --preserveWatchOutput\" \"node --watch --import ./scripts/register-hooks.mjs dist/main.js\"",
    "build": "tsc -p tsconfig.json",
    "start": "node --import ./scripts/register-hooks.mjs dist/main.js",
    "lint": "eslint --ext .ts src",
    "typecheck": "tsc --noEmit",
    "generate": "prisma generate",
    "migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.28",
    "@nestjs/core": "^11.1.28",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.28",
    "@nestjs/swagger": "^11.4.6",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^16.6.1",
    "jsonwebtoken": "^9.0.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.24",
    "@nestjs/schematics": "^11.1.0",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.1.1",
    "@types/passport-jwt": "^4.0.1",
    "@types/web-push": "^3.6.4",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "concurrently": "^10.0.3",
    "eslint": "^10.7.0",
    "globals": "^15.12.0",
    "prisma": "^7.8.0",
    "ts-loader": "^9.6.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.7.0",
    "typescript": "^6"
  }
}
