{
  "name": "codeinit",
  "version": "0.1.0",
  "private": true,
  "description": "CodeInit - Frontend Engineering Job Board with Web Push & Telegram Notifications",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=frontend\" \"npm run dev --workspace=backend\"",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:backend": "npm run dev --workspace=backend",
    "build": "npm run build --workspaces",
    "build:frontend": "npm run build --workspace=frontend",
    "build:backend": "npm run build --workspace=backend",
    "start": "npm run start --workspace=backend",
    "start:frontend": "npm run start --workspace=frontend",
    "lint": "npm run lint --workspaces",
    "typecheck": "npm run typecheck --workspaces",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f postgres",
    "db:migrate": "npm run prisma:migrate --workspace=backend",
    "db:push": "npm run prisma:push --workspace=backend",
    "db:generate": "npm run prisma:generate --workspace=backend",
    "lint:ci": "npm run lint:ci --workspace=frontend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
